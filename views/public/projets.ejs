<div class="ph"><div class="ph-in"><div class="hbadge">Recherche & Innovation</div><h1 style="font-size:clamp(24px,3vw,42px);font-weight:700;color:white;margin-top:12px">Nos Projets</h1></div></div>
<div style="padding:48px 1.5rem;min-height:calc(100vh - 200px);background:var(--cr)"><div style="max-width:1200px;margin:0 auto">
  <div class="yf"><button class="yb on">Tous</button><button class="yb">Énergie</button><button class="yb">IoT</button><button class="yb">Mobilité</button><button class="yb">Gouvernance</button></div>
  <div class="proj-grid">
    <% projects.forEach(p => { %>
      <div class="proj-c">
        <div class="proj-img"><svg viewBox="0 0 24 24"><path d="<%= p.icon %>"/></svg></div>
        <div class="proj-b">
          <div class="proj-axe"><%= p.axe %></div>
          <h3><%= p.title %></h3>
          <p><%= p.description %></p>
          <div class="proj-meta">
            <span class="<%= p.statusClass %>"><%= p.status %></span>
            <span style="font-size:12px;color:var(--gy)"><%= p.period %></span>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div></div>
