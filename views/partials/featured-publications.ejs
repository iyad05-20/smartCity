<div class="events-fs" style="background:<%= index % 2 === 0 ? 'var(--wh)' : 'var(--cr)' %>;">
  <div class="fs-inner">
    <div class="sh-row rv">
      <div><div class="sh-lbl">Recherche & Savoir</div><div class="sh-title">La Publication Star</div><div class="sh-sub">Parcourez les dernières avancées scientifiques de nos chercheurs.</div></div>
      <a href="/publications" class="btn-s">Voir toutes les publications</a>
    </div>
    <div class="ev-list rv">
      <% if (data) { %>
        <a href="/publications" class="ev-it" style="border-left: 4px solid var(--br);align-items:center;">
          <div class="ev-date" style="background:rgba(200,132,42,.1);color:var(--br)"><svg style="width:32px;height:32px;fill:currentColor;display:block;margin:0 auto" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg></div>
          <div class="ev-inf">
            <h3 style="font-size:22px"><%= data.title %></h3>
            <p style="font-size:16px"><%= data.description %></p>
            <div class="ev-meta"><span>✍️ Auteurs: <%= data.authors %></span><span>📅 Année: <%= data.year %></span></div>
          </div>
          <span class="ev-tag" style="font-size:13px;background:var(--dk);color:white"><%= data.type %></span>
        </a>
      <% } else { %>
        <div style="padding:40px;text-align:center;color:var(--gy)">Aucune publication sélectionnée.</div>
      <% } %>
    </div>
  </div>
</div>
